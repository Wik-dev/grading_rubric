# Grading Rubric Studio — environment template (DR-DEP-08).
#
# This is the single source of truth for *which* environment variables the
# L1 package, the L3 integration script, and the L4 SPA build read. Copy
# this file to `.env` (gitignored) for local development. Never commit `.env`.

# ── L1 — gateway / LLM backend (§ 3.7, DR-LLM-09) ────────────────────────
# `stub` runs the deterministic offline gateway and consumes no API tokens.
GR_LLM_BACKEND=anthropic
GR_LLM_MODEL=claude-sonnet-4-20250514
GR_LLM_TEMPERATURE=0.7
GR_LLM_TIMEOUT=60
GR_LLM_RATE_LIMIT_RETRIES=3
GR_LLM_MODEL_RUBRIC_DECOMPOSITION=claude-opus-4-6

# Backend credentials. Only the one matching the active backend must be set.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── L1 — assess stage (DR-AS) ────────────────────────────────────────────
# Optional override for synthetic generation, grading, and pairwise comparison.
GR_ASSESS_LLM_BACKEND=
GR_ASSESS_LLM_MODEL=
GR_ASSESS_MIN_REAL_COPIES=3
GR_ASSESS_PAIRWISE_SAMPLE_SIZE=10
GR_ASSESS_PANEL_SIZE=4
GR_ASSESS_TARGET_RESPONSE_COUNT=10
GR_ASSESS_LLM_CONCURRENCY=4

# ── L1 — improve / score stages ──────────────────────────────────────────
GR_MAX_ITERATIONS=3
GR_SCORER_BACKEND=llm_panel
GR_TRAINED_SCORER_ARTEFACT_PATH=

# ── L3 — Validance integration (§ 3.11, DR-INT-07) ───────────────────────
VALIDANCE_BASE_URL=http://localhost:8001

# ── L4 — SPA build (DR-DEP-04) ───────────────────────────────────────────
VITE_VALIDANCE_BASE_URL=http://localhost:8001
