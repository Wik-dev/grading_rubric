# Grading Rubric Studio — environment template (DR-DEP-08).
#
# This is the single source of truth for *which* environment variables the
# L1 package, the L3 integration script, and the L4 SPA build read. Copy
# this file to `.env` (gitignored) for local development. Never commit `.env`.

# ── OCR (parse stage — Anthropic Sonnet) ──────────────────────────────────
GR_OCR_BACKEND=anthropic
GR_OCR_MODEL=claude-sonnet-4-20250514
GR_LLM_TIMEOUT=60
GR_LLM_RATE_LIMIT_RETRIES=3

# ── Reasoning (rubric decomposition + proposal generation — Opus) ─────────
# Defaults to claude-opus-4-6 when OCR backend is anthropic.
# Set explicitly to override.
GR_REASONING_MODEL=claude-opus-4-6

# Backend credentials. Both are required by default (Anthropic for OCR /
# decomposition / proposals, OpenAI for grader simulation).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ── Grader simulation (assess + score stages — OpenAI GPT-5.4) ───────────
GR_SIMULATION_BACKEND=openai
GR_SIMULATION_MODEL=gpt-5.4
GR_SIMULATION_MIN_REAL_COPIES=3
GR_SIMULATION_PAIRWISE_PAIRS=10
GR_SIMULATION_PANEL_SIZE=4
GR_SIMULATION_TARGET_RESPONSES=10
GR_SIMULATION_CONCURRENCY=4

# ── L1 — improve / score stages ──────────────────────────────────────────
GR_MAX_ITERATIONS=3

# ── L3 — Validance integration (§ 3.11, DR-INT-07) ───────────────────────
VALIDANCE_BASE_URL=http://localhost:8001

# ── L4 — SPA build (DR-DEP-04) ───────────────────────────────────────────
VITE_VALIDANCE_BASE_URL=http://localhost:8001
